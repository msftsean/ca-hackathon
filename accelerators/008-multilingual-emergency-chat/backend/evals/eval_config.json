{
  "eval_name": "multilingual-emergency-chat-accuracy",
  "version": "1.0",
  "description": "Accuracy evaluation for 008 Multilingual Emergency Chatbot",
  "test_cases": [
    {
      "id": "TC-001",
      "message": "Are there any wildfire alerts in Butte County?",
      "language": "en",
      "expected_intent": "active_alerts",
      "expected_emergency_type": "wildfire",
      "min_confidence": 0.85
    },
    {
      "id": "TC-002",
      "message": "Where can I find a shelter near Chico?",
      "language": "en",
      "expected_intent": "shelter_search",
      "min_confidence": 0.80
    },
    {
      "id": "TC-003",
      "message": "Is there an evacuation order for Paradise?",
      "language": "en",
      "expected_intent": "evacuation_status",
      "min_confidence": 0.85
    },
    {
